NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Cloud OAuth (Dropbox / Microsoft PKCE): redirect URI registered with providers must be exactly {NEXT_PUBLIC_APP_URL}/app
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Public site & SEO (production: set NEXT_PUBLIC_SITE_URL to your canonical origin, no trailing slash) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: set to your canonical public origin (no trailing slash), e.g. https://www.draftlensai.com
# Required for correct canonical URLs, sitemap, and OAuth policy links.
NEXT_PUBLIC_ORGANIZATION_LOGO_URL=
NEXT_PUBLIC_CONTACT_EMAIL=
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# Optional: marketing feedback POST body forwarded as Slack-style { text } JSON (Slack incoming webhook URL).
FEEDBACK_WEBHOOK_URL=
