# Copy to apps/api/.env and apps/web/.env.local (or use a single root .env loaded by your process manager).
# Minimal local development values.

DRAFTLENS_ENVIRONMENT=development
DRAFTLENS_SECRET_KEY=dev-only-secret-key-min-32-chars-long!!
DRAFTLENS_COOKIE_NAME=draftlens_session
DRAFTLENS_SESSION_DAYS=30
DRAFTLENS_CORS_ORIGINS=http://localhost:3000

DRAFTLENS_DATA_DIR=./data
DRAFTLENS_DATABASE_URL=sqlite:///./data/draftlens.db

# Add keys to run real multi-model jobs; without keys the API still boots but jobs fail fast with a clear error.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

DRAFTLENS_MODEL_REVIEWER_A=gpt-4.1-mini
DRAFTLENS_MODEL_REVIEWER_B=claude-3-5-haiku-latest
DRAFTLENS_MODEL_REVIEWER_C=gemini-2.0-flash
DRAFTLENS_MODEL_ARBITER=gpt-4.1-mini

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

NEXT_PUBLIC_API_URL=http://localhost:8000
