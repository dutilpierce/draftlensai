# --- Session & app ---
APP_SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# Legacy alias still supported:
# DRAFTLENS_SECRET_KEY=

DRAFTLENS_ENVIRONMENT=development
DRAFTLENS_COOKIE_NAME=draftlens_session
DRAFTLENS_SESSION_DAYS=30
DRAFTLENS_CORS_ORIGINS=http://localhost:3000

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Paths
DRAFTLENS_DATA_DIR=./data
DRAFTLENS_DATABASE_URL=sqlite:///./data/draftlens.db

# LLM providers (configure keys before running live jobs)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Gemini (reviewer model, 429 handling, optional disable — see README “Gemini”)
# Local dev (uncomment to apply):
# DRAFTLENS_GEMINI_MODEL=gemini-3.1-flash-lite
# DRAFTLENS_GEMINI_FALLBACK_MODEL=
# DRAFTLENS_GEMINI_MAX_429_RETRIES=2
# DRAFTLENS_GEMINI_MAX_503_RETRIES=2
# DRAFTLENS_GEMINI_MAX_BACKOFF_SECONDS=5
# DRAFTLENS_OPENAI_MAX_429_RETRIES=2
# DRAFTLENS_OPENAI_MAX_BACKOFF_SECONDS=5
# DRAFTLENS_DISABLE_GEMINI=false
# DRAFTLENS_GEMINI_DISABLE_IN_DEV=false
# Production-style resilience (optional):
# DRAFTLENS_GEMINI_MAX_429_RETRIES=8
# DRAFTLENS_GEMINI_MAX_503_RETRIES=8
# DRAFTLENS_GEMINI_MAX_BACKOFF_SECONDS=90
# DRAFTLENS_OPENAI_MAX_429_RETRIES=8
# DRAFTLENS_OPENAI_MAX_BACKOFF_SECONDS=90
# DRAFTLENS_CONVERGENCE_MAX_CYCLES_REVIEW_CAP=
# DRAFTLENS_CONVERGENCE_MAX_CYCLES_FIX_CAP=

# JSON object with model_routing map (provider/model_id)
MODEL_ROUTING_JSON={"model_routing":{"author_intent_model":"anthropic/claude-sonnet-4-6","skeptical_reviewer_model":"openai/gpt-5.5","consistency_parser_model":"google/gemini-3.1-flash-lite","arbiter_model":"openai/gpt-5.5"}}

# Retention & quotas
DATA_RETENTION_HOURS_DEFAULT=168
DATA_RETENTION_HOURS_SENSITIVE=24
FREE_MONTHLY_PROOFS=1
FREE_MAX_PAGES=25
PRO_FAIR_USE_DOCS_PER_MONTH=200
DRAFTLENS_PRO_MAX_PAGES=500

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_SUCCESS_URL=http://localhost:3000/?billing=success
STRIPE_CANCEL_URL=http://localhost:3000/?billing=cancel

# --- Cloud storage (API serves public client ids to the web; secrets stay here) ---
# Google: OAuth client + Picker browser API key (https://console.cloud.google.com/)
DRAFTLENS_GOOGLE_CLIENT_ID=
DRAFTLENS_GOOGLE_CLIENT_SECRET=
DRAFTLENS_GOOGLE_PICKER_API_KEY=
# Dropbox: app key/secret (https://www.dropbox.com/developers/apps); PKCE works without secret for public clients
DRAFTLENS_DROPBOX_APP_KEY=
DRAFTLENS_DROPBOX_APP_SECRET=
# Microsoft / OneDrive (https://portal.azure.com/ → App registrations)
DRAFTLENS_MICROSOFT_CLIENT_ID=
DRAFTLENS_MICROSOFT_CLIENT_SECRET=
# OAuth redirect for web PKCE flows must match exactly: {NEXT_PUBLIC_APP_URL}/app (e.g. http://localhost:3000/app)
DRAFTLENS_API_PUBLIC_URL=http://127.0.0.1:8000

# --- Next.js web ---
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
